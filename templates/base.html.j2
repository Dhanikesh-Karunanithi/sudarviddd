<!DOCTYPE html>
<html lang="{{ language }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sudar – {{ slides[0].title if slides else "Deck" }}</title>
  {% if theme.google_fonts_url %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="{{ theme.google_fonts_url }}" rel="stylesheet">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="static/css/design-tokens.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --sv-font-heading: {{ theme.font_heading | safe }};
      --sv-font-body: {{ theme.font_body | safe }};
    }

    body {
      background: var(--apple-bg);
      background-image:
        radial-gradient(ellipse 120% 80% at 50% -20%, rgba(255, 255, 255, 0.07), transparent 52%),
        radial-gradient(ellipse 80% 60% at 100% 100%, rgba(255, 255, 255, 0.04), transparent 48%);
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      min-height: 100vh;
      margin: 0;
      font-family: var(--sv-font-body), var(--apple-font);
      padding-bottom: 0;
      box-sizing: border-box;
      text-rendering: optimizeLegibility;
      -webkit-font-smoothing: antialiased;
      font-feature-settings: "kern" 1, "liga" 1;
    }

    #sudarvid-deck-stage {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 0;
      width: 100%;
      padding: 8px;
      box-sizing: border-box;
    }

    #deck-viewport {
      overflow: hidden;
      flex-shrink: 0;
      position: relative;
    }

    #deck-scale-inner {
      transform-origin: top left;
      will-change: transform;
      position: absolute;
      left: 0;
      top: 0;
    }

    #deck {
      container-type: inline-size;
      container-name: sudarvid-deck;
      position: relative;
      width: {{ width }}px;
      height: {{ height }}px;
      overflow: hidden;
      background: {{ theme.bg_color }};
    }

    #slide-progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      width: 0%;
      z-index: 100;
      background: linear-gradient(90deg, #ffffff, rgba(255, 255, 255, 0.5));
      transition: width 0.4s ease;
      pointer-events: none;
    }

    #sudarvid-capture-sweep {
      position: absolute;
      inset: 0;
      z-index: 99;
      pointer-events: none;
      opacity: 0;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.14) 45%,
        transparent 90%
      );
      background-size: 200% 100%;
    }
    #sudarvid-capture-sweep.sweep-active {
      animation: sudarvidSweep 0.4s ease-out forwards;
    }
    @keyframes sudarvidSweep {
      0% { opacity: 0; background-position: 100% 0; }
      35% { opacity: 1; }
      100% { opacity: 0; background-position: -100% 0; }
    }

    .slide-ambient {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }
    .slide-ambient .ambient-svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    .layout-intro .slide-ambient,
    .layout-outro .slide-ambient {
      display: none;
    }

    body[data-animation-level="dynamic"] .slide {
      transition: opacity 0.42s ease;
    }

    {% if animation_level != 'dynamic' %}
    .slide.active.visual-full_bleed_bg .slide-image-wrap .slide-image,
    .slide.active:not(.visual-split_right):not(.visual-split_left):not(.visual-top_band):not(.visual-inset_card) .slide-image-wrap .slide-image {
      animation: kenBurns 12s ease-in-out both;
      transform-origin: center center;
    }
    @keyframes kenBurns {
      0%   { transform: scale(1.08) translate(0px, 0px); }
      50%  { transform: scale(1.14) translate(-18px, -10px); }
      100% { transform: scale(1.10) translate(8px, 6px); }
    }
    {% endif %}

    .layout-intro .slide-content--intro,
    .layout-outro .slide-content--outro {
      max-width: 92%;
      text-align: center;
      justify-content: center;
      align-items: center;
      margin: 0 auto;
    }
    .layout-quiz {
      background: #09090b !important;
      color: #f5f5f7 !important;
    }
    .slide-content--quiz {
      max-width: min(88%, 860px);
      margin: 0 auto;
      text-align: left;
    }
    .quiz-options {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      margin-top: 20px;
    }
    .quiz-option {
      width: 100%;
      text-align: left;
      border-radius: 12px;
      border: 1px solid color-mix(in srgb, {{ theme.accent_color }} 38%, transparent);
      background: color-mix(in srgb, #fff 7%, transparent);
      color: inherit;
      padding: 14px 16px;
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(14px, 1.5vw, 20px);
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    }
    .quiz-option:hover {
      transform: translateY(-1px);
      border-color: color-mix(in srgb, {{ theme.accent_color }} 70%, transparent);
    }
    .quiz-option.is-correct {
      background: color-mix(in srgb, #22c55e 28%, transparent);
      border-color: color-mix(in srgb, #22c55e 76%, transparent);
    }
    .quiz-option.is-wrong {
      background: color-mix(in srgb, #ef4444 24%, transparent);
      border-color: color-mix(in srgb, #ef4444 72%, transparent);
    }
    .quiz-feedback {
      margin-top: 14px;
      min-height: 24px;
      font-size: clamp(13px, 1.3vw, 18px);
      font-family: var(--sv-font-body), var(--apple-font);
      color: color-mix(in srgb, #f5f5f7 86%, transparent);
    }
    .layout-intro {
      background: #000000 !important;
      color: #f5f5f7 !important;
    }
    .slide-title--intro {
      font-size: clamp(32px, 11cqw, 72px);
      font-weight: 700;
      letter-spacing: -0.03em;
    }
    .bookend-logo-wrap {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    .bookend-logo-mark {
      width: clamp(120px, 14cqw, 220px);
      height: auto;
      filter: drop-shadow(0 0 32px color-mix(in srgb, {{ theme.accent_color }} 60%, transparent));
    }
    .bookend-logo-wordmark {
      font-family: var(--sv-font-heading), var(--apple-font);
      font-size: clamp(28px, 5cqw, 64px);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #f5f5f7;
      opacity: 0.95;
    }
    .bookend-logo-tagline {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(12px, 1.7cqw, 18px);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: color-mix(in srgb, #f5f5f7 84%, transparent);
    }
    .layout-outro {
      background: #000000 !important;
      color: #f5f5f7 !important;
    }
    .layout-intro .bookend-logo-wrap {
      animation: introLogoIn 1000ms cubic-bezier(0.22, 0.68, 0, 1.3) both;
    }
    .layout-outro .bookend-logo-wrap {
      animation: outroLogoOut 1300ms ease-in-out both;
    }
    @keyframes introLogoIn {
      0% { opacity: 0; transform: translateY(18px) scale(0.9); }
      100% { opacity: 1; transform: translateY(0) scale(1); }
    }
    @keyframes outroLogoOut {
      0%, 62% { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(0.88); }
    }

    .slide {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 64px;
      opacity: 0;
      pointer-events: none;
      transform: scale(1.015);
      transition: opacity 0.42s ease, transform 0.5s ease;
      background: {{ theme.bg_color }};
      color: {{ theme.text_color }};
      overflow: hidden;
      text-rendering: optimizeLegibility;
      -webkit-font-smoothing: antialiased;
      font-feature-settings: "kern" 1, "liga" 1;
    }

    .slide.active {
      opacity: 1;
      pointer-events: auto;
      transform: scale(1);
    }

    .slide-image-wrap {
      position: absolute;
      inset: 0;
      z-index: 0;
    }
    .slide-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.58;
    }
    .slide-image-overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          96deg,
          color-mix(in srgb, {{ theme.bg_color }} 14%, transparent) 4%,
          color-mix(in srgb, {{ theme.bg_color }} 4%, transparent) 36%,
          color-mix(in srgb, {{ theme.bg_color }} 6%, transparent) 62%,
          color-mix(in srgb, {{ theme.bg_color }} 20%, transparent) 100%
        );
      z-index: 1;
    }

    .slide-content {
      position: relative;
      z-index: 2;
      max-width: 72%;
    }
    .slide.visual-full_bleed_bg .slide-content {
      max-width: min(72%, 48cqw);
    }

    /* —— Layout variants (learning / editorial decks) —— */
    .layout-hero .slide-content { max-width: 88%; }
    .layout-hero .slide-title {
      font-size: clamp(42px, 6.5vw, 92px);
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }
    .slide-subtitle {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(16px, 2vw, 26px);
      line-height: 1.45;
      opacity: 0.88;
      margin-bottom: 24px;
      max-width: 36em;
    }
    .slide-learn-card {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(15px, 1.55vw, 20px);
      line-height: 1.55;
      padding: 20px 22px;
      border-radius: 14px;
      border-left: 5px solid {{ theme.accent_color }};
      background: color-mix(in srgb, {{ theme.text_color }} 7%, transparent);
      margin-bottom: 18px;
    }
    .slide-learn-label {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: {{ theme.accent_color }};
      margin-bottom: 8px;
    }
    .layout-split_learn .slide-content {
      display: grid;
      grid-template-columns: 1fr 1.05fr;
      gap: 28px 36px;
      max-width: 94%;
      align-items: start;
    }
    .layout-split_learn .slide-head { grid-column: 1 / -1; }
    .slide-bullet-cards { display: flex; flex-direction: column; gap: 12px; }
    .slide-bullet-card {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(14px, 1.45vw, 19px);
      line-height: 1.5;
      padding: 14px 16px;
      border-radius: 12px;
      background: color-mix(in srgb, {{ theme.text_color }} 9%, transparent);
      border: 1px solid color-mix(in srgb, {{ theme.accent_color }} 35%, transparent);
      transform-origin: left center;
    }
    .layout-steps .slide-content { max-width: 88%; }
    .slide-step-list { list-style: none; padding: 0; margin: 0; counter-reset: sudarstep; }
    .slide-step-list li {
      counter-increment: sudarstep;
      position: relative;
      padding: 16px 18px 16px 56px;
      margin-bottom: 12px;
      border-radius: 12px;
      background: color-mix(in srgb, {{ theme.text_color }} 8%, transparent);
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(14px, 1.5vw, 20px);
      line-height: 1.5;
    }
    .slide-step-list li::before {
      content: counter(sudarstep, decimal-leading-zero);
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      font-family: var(--sv-font-heading), var(--apple-font);
      font-weight: 800;
      font-size: 20px;
      color: {{ theme.accent_color }};
    }
    .layout-contrast .slide-content { max-width: 92%; }
    .slide-contrast-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 28px;
      margin-top: 8px;
    }
    .slide-contrast-col {
      padding: 18px 20px;
      border-radius: 14px;
      background: color-mix(in srgb, {{ theme.text_color }} 6%, transparent);
      border-top: 3px solid {{ theme.accent_color }};
    }
    .slide-contrast-col h3 {
      font-family: var(--sv-font-heading), var(--apple-font);
      font-size: clamp(18px, 2vw, 26px);
      margin-bottom: 10px;
    }
    .slide-contrast-col p {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(14px, 1.45vw, 19px);
      line-height: 1.55;
      opacity: 0.92;
    }
    .layout-stat_focus .slide-content { max-width: 90%; }
    .slide-stat-block {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 12px 24px;
      margin: 12px 0 22px;
    }
    .slide-big-stat {
      font-family: var(--sv-font-heading), var(--apple-font);
      font-weight: 800;
      font-size: clamp(56px, 9vw, 120px);
      line-height: 1;
      letter-spacing: -0.03em;
      color: {{ theme.accent_color }};
    }
    .slide-stat-caption {
      font-family: var(--sv-font-body), var(--apple-font);
      font-size: clamp(15px, 1.6vw, 22px);
      max-width: 14em;
      line-height: 1.4;
    }

    .slide-nav-label {
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: {{ theme.accent_color }};
      margin-bottom: 20px;
      font-family: var(--sv-font-body), var(--apple-font);
    }

    .slide-title {
      font-family: var(--sv-font-heading), var(--apple-font);
      color: {{ theme.text_color }};
      margin-bottom: 28px;
      line-height: 1.08;
      font-size: clamp(28px, 9cqw, 84px);
      font-weight: 800;
      overflow-wrap: anywhere;
      word-break: break-word;
      hyphens: auto;
    }

    .slide-text-col .slide-title {
      font-size: clamp(22px, 7cqw, 64px);
    }

    .slide-bullets {
      list-style: disc;
      padding-left: 1.4em;
    }
    .slide-bullets li {
      font-family: var(--sv-font-body), var(--apple-font);
      color: {{ theme.text_color }};
      margin-bottom: 10px;
      line-height: 1.65;
      font-size: clamp(14px, 1.6vw, 22px);
    }

    .slide-accent-bar {
      height: 6px;
      width: 80px;
      background: {{ theme.accent_color }};
      margin-bottom: 20px;
      border-radius: 2px;
    }

    .slide-index {
      position: absolute;
      bottom: 28px;
      right: 36px;
      font-size: 11px;
      letter-spacing: 0.15em;
      color: {{ theme.accent_color }};
      opacity: 0.7;
      font-family: var(--sv-font-body), var(--apple-font);
      z-index: 10;
    }

    /* —— Visual templates: image placement (LLM-selected) —— */
    .slide.visual-full_bleed_bg { padding: 0; }
    .slide.visual-split_right,
    .slide.visual-split_left {
      justify-content: stretch;
      align-items: stretch;
    }
    .slide.visual-top_band { justify-content: flex-start; }
    .slide.visual-inset_card { justify-content: flex-start; align-items: stretch; }
    .slide.visual-inset_card .slide-inset-shell { flex: 1; min-height: 0; }
    .slide.visual-full_bleed_bg .slide-bleed-foreground {
      position: relative;
      z-index: 2;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100%;
      padding: 64px;
      box-sizing: border-box;
    }

    .slide.visual-split_right,
    .slide.visual-split_left,
    .slide.visual-top_band,
    .slide.visual-inset_card { padding: 0; }

    .slide-split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
      flex: 1;
      min-height: 0;
      width: 100%;
    }
    .slide-split.slide-split-single { grid-template-columns: 1fr; }

    .slide-text-col {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 0;
      overflow: auto;
      padding: 52px 40px 56px 64px;
      box-sizing: border-box;
    }
    .slide-text-col .slide-content { max-width: 100%; }

    .slide-media-col {
      display: flex;
      align-items: stretch;
      justify-content: stretch;
      padding: 28px 40px 28px 28px;
      box-sizing: border-box;
      min-height: 0;
      background: color-mix(in srgb, {{ theme.text_color }} 5%, transparent);
    }
    .slide-split-left .slide-media-col {
      padding: 28px 28px 28px 40px;
    }

    .slide.visual-split_right .slide-media-frame,
    .slide.visual-split_left .slide-media-frame {
      width: 100%;
      height: 100%;
      max-width: none;
      min-height: 0;
      flex: 1;
      aspect-ratio: auto;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 44px color-mix(in srgb, #000 26%, transparent);
      border: 1px solid color-mix(in srgb, {{ theme.text_color }} 14%, transparent);
    }
    .slide-media-frame {
      width: 100%;
      max-width: 520px;
      aspect-ratio: 4 / 3;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 20px 44px color-mix(in srgb, #000 26%, transparent);
      border: 1px solid color-mix(in srgb, {{ theme.text_color }} 14%, transparent);
    }
    .slide-media-col .slide-media-frame .slide-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 1;
    }
    .slide-media-frame .slide-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 1;
    }

    .slide.visual-top_band {
      flex-direction: column;
      justify-content: flex-start;
    }
    .slide-top-band {
      flex: 0 0 40%;
      max-height: 46%;
      min-height: 200px;
      position: relative;
      overflow: hidden;
      background: color-mix(in srgb, {{ theme.text_color }} 6%, transparent);
    }
    .slide-top-band .slide-media-frame {
      position: absolute;
      inset: 0;
      max-width: none;
      width: 100%;
      height: 100%;
      border-radius: 0;
      aspect-ratio: auto;
      border: none;
      box-shadow: none;
    }
    .slide-top-band .slide-media-frame .slide-image {
      object-fit: cover;
    }
    .slide-stack-body {
      flex: 1;
      padding: 48px 64px 60px;
      overflow: auto;
      box-sizing: border-box;
      min-height: 0;
    }
    .slide-stack-body .slide-content { max-width: 92%; }

    .slide-inset-shell {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 32%);
      gap: 32px;
      align-items: start;
      flex: 1;
      padding: 52px 56px 64px 64px;
      box-sizing: border-box;
      min-height: 0;
      overflow: auto;
    }
    .slide-inset-shell.slide-inset-single {
      grid-template-columns: 1fr;
    }
    .slide-inset-shell .slide-content { max-width: 100%; }
    .slide-inset-aside {
      position: sticky;
      top: 48px;
    }
    .slide-inset-aside .slide-media-frame {
      max-width: 100%;
      aspect-ratio: 1 / 1;
    }

    .slide-visual-none-inner {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 0;
      padding: 64px;
      box-sizing: border-box;
    }

    #sudarvid-chrome {
      position: sticky;
      bottom: 0;
      z-index: 1000;
      flex-shrink: 0;
    }

    #sudarvid-caption-wrap {
      background: color-mix(in srgb, var(--apple-surface, #1c1c1e) 92%, transparent);
      backdrop-filter: var(--apple-blur, blur(20px));
      -webkit-backdrop-filter: var(--apple-blur, blur(20px));
      border-top: 1px solid var(--apple-border, rgba(255, 255, 255, 0.12));
      padding: 10px 16px 8px;
      max-height: 22vh;
      overflow-y: auto;
    }

    #sudarvid-caption {
      margin: 0;
      font-size: clamp(13px, 2.5vw, 17px);
      line-height: 1.45;
      color: var(--apple-text-primary, rgba(255, 255, 255, 0.95));
      font-family: var(--sv-font-body), var(--apple-font);
      text-align: center;
      letter-spacing: 0.01em;
    }
    #sudarvid-caption .sv-word {
      opacity: 0.34;
      transition: opacity 0.14s ease;
    }
    #sudarvid-caption .sv-word.is-spoken {
      opacity: 0.78;
    }
    #sudarvid-caption .sv-word.is-current {
      opacity: 1;
      font-weight: 700;
    }

    /* Bottom playback controls (hidden during headless capture — see sudarvid.js) */
    #sudarvid-player-ui {
      position: relative;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1001;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px 14px;
      padding: 12px 16px;
      background: var(--apple-surface);
      backdrop-filter: var(--apple-blur);
      -webkit-backdrop-filter: var(--apple-blur);
      border-top: 1px solid var(--apple-border);
      font-family: var(--apple-font);
      box-sizing: border-box;
      box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.35);
    }
    #sudarvid-timeline {
      position: relative;
      flex: 1 1 220px;
      min-width: 140px;
      height: 10px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--apple-text-primary) 14%, transparent);
      overflow: hidden;
      cursor: pointer;
      border: 1px solid color-mix(in srgb, var(--apple-accent) 35%, transparent);
    }
    #sudarvid-timeline-fill {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 0%;
      border-radius: inherit;
      background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--apple-accent) 90%, white 10%),
        color-mix(in srgb, var(--apple-accent) 70%, white 30%)
      );
      transition: width 120ms linear;
    }
    #sudarvid-player-ui button {
      background: var(--apple-glass);
      color: var(--apple-text-primary);
      border: 1px solid var(--apple-border);
      border-radius: 980px;
      padding: 8px 18px;
      font-weight: 600;
      cursor: pointer;
      font-size: 13px;
      letter-spacing: -0.01em;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    #sudarvid-player-ui button:hover {
      transform: scale(1.03);
      box-shadow: 0 0 24px rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.1);
    }
    #sudarvid-player-ui button:focus-visible {
      outline: 2px solid var(--apple-accent);
      outline-offset: 2px;
    }
    #sudarvid-scrub {
      flex: 1 1 180px;
      min-width: 100px;
      height: 20px;
      margin: 0;
      padding: 0;
      background: transparent;
      cursor: pointer;
      -webkit-appearance: none;
      appearance: none;
      accent-color: var(--apple-accent);
    }
    #sudarvid-scrub::-webkit-slider-runnable-track {
      height: 3px;
      border-radius: 2px;
      background: rgba(255, 255, 255, 0.15);
    }
    #sudarvid-scrub::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 14px;
      height: 14px;
      margin-top: -5px;
      border-radius: 50%;
      background: var(--apple-accent);
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.35);
      cursor: pointer;
    }
    #sudarvid-scrub::-moz-range-track {
      height: 3px;
      border-radius: 2px;
      background: rgba(255, 255, 255, 0.15);
    }
    #sudarvid-scrub::-moz-range-thumb {
      width: 14px;
      height: 14px;
      border: none;
      border-radius: 50%;
      background: var(--apple-accent);
      box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.35);
      cursor: pointer;
    }
    #sudarvid-time {
      font-size: 12px;
      letter-spacing: 0.03em;
      color: var(--apple-text-secondary);
      opacity: 1;
      min-width: 8.5em;
      font-variant-numeric: tabular-nums;
    }
    #sudarvid-hint {
      width: 100%;
      flex-basis: 100%;
      font-size: 10px;
      opacity: 0.55;
      color: rgba(250, 250, 250, 0.45);
      margin: 0;
    }

    {{ theme.css_extra | safe }}

    {% if animation_level == 'subtle' %}
    .slide.active .slide-content  { animation: fadeInUp 0.85s cubic-bezier(.22,.68,0,1.2) both; }
    .slide.active .slide-nav-label{ animation: fadeIn 0.6s ease both; }
    .slide.active .slide-media-frame .slide-image { animation: frameDrift 12s ease-in-out both; }
    .slide.active .slide-subtitle { animation: fadeInUp 0.75s ease 0.12s both; }
    .slide.active .slide-learn-card { animation: fadeInUp 0.7s ease 0.1s both; }
    .slide.active .slide-bullet-card:nth-child(1) { animation: fadeInUp 0.65s ease 0.2s both; }
    .slide.active .slide-bullet-card:nth-child(2) { animation: fadeInUp 0.65s ease 0.32s both; }
    .slide.active .slide-bullet-card:nth-child(3) { animation: fadeInUp 0.65s ease 0.44s both; }
    .slide.active .slide-bullet-card:nth-child(4) { animation: fadeInUp 0.65s ease 0.56s both; }
    .slide.active .slide-step-list li:nth-child(1) { animation: fadeInUp 0.6s ease 0.2s both; }
    .slide.active .slide-step-list li:nth-child(2) { animation: fadeInUp 0.6s ease 0.34s both; }
    .slide.active .slide-step-list li:nth-child(3) { animation: fadeInUp 0.6s ease 0.48s both; }
    .slide.active .slide-step-list li:nth-child(4) { animation: fadeInUp 0.6s ease 0.62s both; }
    .slide.active .slide-contrast-col:nth-child(1) { animation: fadeInUp 0.7s ease 0.15s both; }
    .slide.active .slide-contrast-col:nth-child(2) { animation: fadeInUp 0.7s ease 0.3s both; }
    .slide.active .slide-big-stat { animation: fadeInUp 0.8s ease 0.1s both; }
    .slide.active .slide-stat-caption { animation: fadeIn 0.7s ease 0.25s both; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes frameDrift { from { transform: scale(1.02); } to { transform: scale(1.06); } }
    {% endif %}

    {% if animation_level == 'medium' %}
    .slide.active .slide-nav-label { animation: slideInLeft 0.5s ease both; }
    .slide.active .slide-title { animation: fadeInUp 0.7s cubic-bezier(.22,.68,0,1.2) 0.15s both; }
    .slide.active .slide-bullets li:nth-child(1) { animation: fadeInUp 0.6s ease 0.30s both; }
    .slide.active .slide-bullets li:nth-child(2) { animation: fadeInUp 0.6s ease 0.44s both; }
    .slide.active .slide-bullets li:nth-child(3) { animation: fadeInUp 0.6s ease 0.58s both; }
    .slide.active .slide-bullets li:nth-child(4) { animation: fadeInUp 0.6s ease 0.72s both; }
    .slide.active .slide-bullets li:nth-child(5) { animation: fadeInUp 0.6s ease 0.86s both; }
    .slide.active .slide-subtitle { animation: slideInLeft 0.55s ease 0.2s both; }
    .slide.active .slide-learn-card { animation: fadeInUp 0.65s cubic-bezier(.22,.68,0,1.2) 0.18s both; }
    .slide.active .slide-bullet-card:nth-child(n) { animation: cardPop 0.55s cubic-bezier(.34,1.56,.64,1) both; }
    .slide.active .slide-bullet-card:nth-child(1) { animation-delay: 0.22s; }
    .slide.active .slide-bullet-card:nth-child(2) { animation-delay: 0.36s; }
    .slide.active .slide-bullet-card:nth-child(3) { animation-delay: 0.5s; }
    .slide.active .slide-bullet-card:nth-child(4) { animation-delay: 0.64s; }
    .slide.active .slide-step-list li:nth-child(1) { animation: slideInLeft 0.5s ease 0.25s both; }
    .slide.active .slide-step-list li:nth-child(2) { animation: slideInLeft 0.5s ease 0.4s both; }
    .slide.active .slide-step-list li:nth-child(3) { animation: slideInLeft 0.5s ease 0.55s both; }
    .slide.active .slide-step-list li:nth-child(4) { animation: slideInLeft 0.5s ease 0.7s both; }
    .slide.active .slide-contrast-col:nth-child(1) { animation: fadeInUp 0.6s ease 0.2s both; }
    .slide.active .slide-contrast-col:nth-child(2) { animation: fadeInUp 0.6s ease 0.38s both; }
    .slide.active .slide-big-stat { animation: cardPop 0.7s cubic-bezier(.34,1.56,.64,1) 0.12s both; }
    .slide.active .slide-stat-caption { animation: fadeInUp 0.55s ease 0.28s both; }
    .slide.active .slide-media-frame .slide-image { animation: frameDriftMed 11s ease-in-out both; }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes slideInLeft { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes frameDriftMed { 0% { transform: scale(1.03) translateY(0px); } 100% { transform: scale(1.08) translateY(-6px); } }
    @keyframes cardPop { from { opacity: 0; transform: translateY(16px) scale(0.96); } to { opacity: 1; transform: translateY(0) scale(1); } }
    {% endif %}

    {% if animation_level == 'dynamic' %}
    .slide.active.visual-full_bleed_bg .slide-image-wrap .slide-image { animation: parallaxReveal 1.1s cubic-bezier(.22,.68,0,1.2) both; }
    .slide.active .slide-media-frame .slide-image { animation: frameReveal 1s cubic-bezier(.22,.68,0,1.2) both; }
    .slide.active .slide-nav-label { animation: blastIn 0.45s cubic-bezier(.22,.68,0,1.5) both; }
    .slide.active .slide-title { animation: parallaxUp 0.75s cubic-bezier(.22,.68,0,1.3) 0.12s both; }
    .slide.active .slide-accent-bar { animation: expandBar 0.6s ease 0.3s both; }
    .slide.active .slide-bullets li:nth-child(1) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.35s both; }
    .slide.active .slide-bullets li:nth-child(2) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.48s both; }
    .slide.active .slide-bullets li:nth-child(3) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.61s both; }
    .slide.active .slide-bullets li:nth-child(4) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.74s both; }
    .slide.active .slide-bullets li:nth-child(5) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.87s both; }
    .slide.active .slide-subtitle { animation: parallaxUp 0.65s cubic-bezier(.22,.68,0,1.3) 0.22s both; }
    .slide.active .slide-learn-card { animation: snapIn 0.45s cubic-bezier(.22,.68,0,1.5) 0.2s both; }
    .slide.active .slide-bullet-card:nth-child(1) { animation: snapIn 0.42s cubic-bezier(.22,.68,0,1.5) 0.32s both; }
    .slide.active .slide-bullet-card:nth-child(2) { animation: snapIn 0.42s cubic-bezier(.22,.68,0,1.5) 0.46s both; }
    .slide.active .slide-bullet-card:nth-child(3) { animation: snapIn 0.42s cubic-bezier(.22,.68,0,1.5) 0.6s both; }
    .slide.active .slide-bullet-card:nth-child(4) { animation: snapIn 0.42s cubic-bezier(.22,.68,0,1.5) 0.74s both; }
    .slide.active .slide-step-list li:nth-child(1) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.34s both; }
    .slide.active .slide-step-list li:nth-child(2) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.48s both; }
    .slide.active .slide-step-list li:nth-child(3) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.62s both; }
    .slide.active .slide-step-list li:nth-child(4) { animation: snapIn 0.4s cubic-bezier(.22,.68,0,1.5) 0.76s both; }
    .slide.active .slide-contrast-col:nth-child(1) { animation: blastIn 0.5s cubic-bezier(.22,.68,0,1.5) 0.25s both; }
    .slide.active .slide-contrast-col:nth-child(2) { animation: blastIn 0.5s cubic-bezier(.22,.68,0,1.5) 0.42s both; }
    .slide.active .slide-big-stat { animation: parallaxUp 0.85s cubic-bezier(.22,.68,0,1.3) 0.08s both; }
    .slide.active .slide-stat-caption { animation: snapIn 0.45s ease 0.3s both; }
    @keyframes parallaxReveal { from { opacity: 0.4; transform: scale(1.14) translateY(-20px); } to { opacity: 1; transform: scale(1.08) translateY(0); } }
    @keyframes frameReveal { from { opacity: 0.85; transform: scale(1.05); } to { opacity: 1; transform: scale(1.02); } }
    @keyframes parallaxUp { from { opacity: 0; transform: translateY(44px) skewY(1.5deg); } to { opacity: 1; transform: translateY(0) skewY(0deg); } }
    @keyframes blastIn { from { opacity: 0; transform: translateX(-32px) scale(0.9); } to { opacity: 1; transform: translateX(0) scale(1); } }
    @keyframes snapIn { from { opacity: 0; transform: translateX(-16px); } to { opacity: 1; transform: translateX(0); } }
    @keyframes expandBar { from { width: 0; } to { width: 80px; } }
    {% endif %}
  </style>
</head>
<body data-animation-level="{{ animation_level }}">
{% macro slide_inner(slide, slides) %}
      {% if slide.layout_kind == 'intro' %}
      <div class="slide-content slide-content--bookend slide-content--intro">
        <div class="bookend-logo-wrap" aria-label="Sudar intro logo">
          <svg class="bookend-logo-mark" viewBox="0 0 128 128" role="img" aria-hidden="true">
            <defs>
              <linearGradient id="sv-g-intro" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7C3AED" />
                <stop offset="100%" stop-color="#06B6D4" />
              </linearGradient>
            </defs>
            <rect x="8" y="8" width="112" height="112" rx="30" fill="url(#sv-g-intro)" />
            <path d="M37 64c0-15 12-27 27-27h27v12H64c-8 0-15 7-15 15s7 15 15 15h27v12H64c-15 0-27-12-27-27Z" fill="white"/>
            <circle cx="97" cy="31" r="7" fill="white"/>
          </svg>
          <div class="bookend-logo-wordmark">Sudar</div>
          <div class="bookend-logo-tagline">Learns With You, For You</div>
          <h1 class="slide-title slide-title--intro">{{ slide.title }}</h1>
          {% if slide.subtitle %}
          <p class="slide-subtitle">{{ slide.subtitle }}</p>
          {% endif %}
        </div>
      </div>

      {% elif slide.layout_kind == 'outro' %}
      <div class="slide-content slide-content--bookend slide-content--outro">
        <div class="bookend-logo-wrap" aria-label="Sudar outro logo">
          <svg class="bookend-logo-mark" viewBox="0 0 128 128" role="img" aria-hidden="true">
            <defs>
              <linearGradient id="sv-g-outro" x1="100%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#06B6D4" />
                <stop offset="100%" stop-color="#7C3AED" />
              </linearGradient>
            </defs>
            <rect x="8" y="8" width="112" height="112" rx="30" fill="url(#sv-g-outro)" />
            <path d="M37 64c0-15 12-27 27-27h27v12H64c-8 0-15 7-15 15s7 15 15 15h27v12H64c-15 0-27-12-27-27Z" fill="white"/>
            <circle cx="97" cy="31" r="7" fill="white"/>
          </svg>
          <div class="bookend-logo-wordmark">Sudar</div>
          <div class="bookend-logo-tagline">Keep Learning</div>
        </div>
      </div>

      {% elif slide.layout_kind == 'quiz' %}
      <div class="slide-content slide-content--quiz">
        <div class="slide-nav-label">Quiz Checkpoint</div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        {% if slide.subtitle %}
        <p class="slide-subtitle">{{ slide.subtitle }}</p>
        {% endif %}
        {% if slide.bullets %}
        <div class="quiz-options" role="group" aria-label="Quiz options">
          {% for bullet in slide.bullets %}
          <button class="quiz-option" type="button" data-option-index="{{ loop.index0 }}">{{ bullet }}</button>
          {% endfor %}
        </div>
        {% endif %}
        <p class="quiz-feedback" aria-live="polite">Select an answer to continue.</p>
      </div>

      {% elif slide.layout_kind == 'hero' %}
      <div class="slide-content">
        <div class="slide-nav-label">
          {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
        </div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        {% if slide.subtitle %}
        <p class="slide-subtitle">{{ slide.subtitle }}</p>
        {% endif %}
        {% if slide.bullets %}
        <ul class="slide-bullets">
          {% for bullet in slide.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>

      {% elif slide.layout_kind == 'split_learn' %}
      <div class="slide-content">
        <div class="slide-head">
          <div class="slide-nav-label">
            {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
          </div>
          <div class="slide-accent-bar"></div>
          <h1 class="slide-title">{{ slide.title }}</h1>
          {% if slide.subtitle %}
          <p class="slide-subtitle">{{ slide.subtitle }}</p>
          {% endif %}
        </div>
        {% if slide.learning_point %}
        <div>
          <div class="slide-learn-card">
            <div class="slide-learn-label">Learning focus</div>
            {{ slide.learning_point }}
          </div>
        </div>
        {% endif %}
        <div class="slide-bullet-cards">
          {% for bullet in slide.bullets %}
          <div class="slide-bullet-card">{{ bullet }}</div>
          {% endfor %}
        </div>
      </div>

      {% elif slide.layout_kind == 'steps' %}
      <div class="slide-content">
        <div class="slide-nav-label">
          {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
        </div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        {% if slide.subtitle %}
        <p class="slide-subtitle">{{ slide.subtitle }}</p>
        {% endif %}
        {% if slide.bullets %}
        <ol class="slide-step-list">
          {% for bullet in slide.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ol>
        {% endif %}
      </div>

      {% elif slide.layout_kind == 'contrast' and slide.bullets|length >= 4 %}
      <div class="slide-content">
        <div class="slide-nav-label">
          {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
        </div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        <div class="slide-contrast-grid">
          <div class="slide-contrast-col">
            <h3>{{ slide.bullets[0] }}</h3>
            <p>{{ slide.bullets[1] }}</p>
          </div>
          <div class="slide-contrast-col">
            <h3>{{ slide.bullets[2] }}</h3>
            <p>{{ slide.bullets[3] }}</p>
          </div>
        </div>
      </div>

      {% elif slide.layout_kind == 'stat_focus' and slide.big_stat %}
      <div class="slide-content">
        <div class="slide-nav-label">
          {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
        </div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        <div class="slide-stat-block">
          <span class="slide-big-stat">{{ slide.big_stat }}</span>
          {% if slide.stat_caption %}
          <span class="slide-stat-caption">{{ slide.stat_caption }}</span>
          {% endif %}
        </div>
        {% if slide.bullets %}
        <ul class="slide-bullets">
          {% for bullet in slide.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>

      {% else %}
      <div class="slide-content">
        <div class="slide-nav-label">
          {{ "%02d" % (slide.index + 1) }} / {{ "%02d" % (slides|length) }}
        </div>
        <div class="slide-accent-bar"></div>
        <h1 class="slide-title">{{ slide.title }}</h1>
        {% if slide.subtitle %}
        <p class="slide-subtitle">{{ slide.subtitle }}</p>
        {% endif %}
        {% if slide.learning_point %}
        <div class="slide-learn-card">
          <div class="slide-learn-label">Takeaway</div>
          {{ slide.learning_point }}
        </div>
        {% endif %}
        {% if slide.bullets %}
        <ul class="slide-bullets">
          {% for bullet in slide.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endif %}
{% endmacro %}

  <div id="sudarvid-deck-stage">
    <div id="deck-viewport">
      <div id="deck-scale-inner">
  <div id="deck">
    <div id="slide-progress-bar" aria-hidden="true"></div>
    <div id="sudarvid-capture-sweep" aria-hidden="true"></div>
    {% for slide in slides %}
    {% set eff = namespace(kind=slide.layout_kind or 'standard') %}
    {% if eff.kind in ('intro', 'outro') %}
      {% set vt = 'none' %}
    {% else %}
      {% if eff.kind == 'contrast' and slide.bullets|length < 4 %}{% set eff.kind = 'standard' %}{% endif %}
      {% if eff.kind == 'stat_focus' and not slide.big_stat %}{% set eff.kind = 'standard' %}{% endif %}
      {% set vt = slide.visual_template | default('full_bleed_bg') %}
    {% endif %}
    <section
      class="slide layout-{{ eff.kind }} visual-{{ vt }}{% if loop.first %} active{% endif %}"
      data-index="{{ slide.index }}"
      data-duration="{{ slide.duration_seconds }}"
      data-layout="{{ eff.kind }}"
      data-visual-template="{{ vt }}"
      {% if eff.kind == 'quiz' %}data-quiz-correct-index="{{ slide.quiz_correct_index | default(0) }}"{% endif %}
      {% if eff.kind == 'quiz' %}data-quiz-explanation="{{ slide.quiz_explanation | default('') }}"{% endif %}
    >
      <div class="slide-ambient" aria-hidden="true">
        <svg class="ambient-svg" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice">
          <defs>
            <radialGradient id="orb-{{ slide.index }}" cx="70%" cy="30%" r="55%">
              <stop offset="0%" stop-color="{{ theme.accent_color }}" stop-opacity="0.18"/>
              <stop offset="100%" stop-color="transparent" stop-opacity="0"/>
            </radialGradient>
          </defs>
          <ellipse cx="900" cy="200" rx="500" ry="380" fill="url(#orb-{{ slide.index }})">
            <animateTransform attributeName="transform" type="translate"
              values="0 0; -30 20; 0 0" dur="9s" repeatCount="indefinite"/>
          </ellipse>
        </svg>
      </div>
      {% if vt == 'full_bleed_bg' %}
      {% if slide.image_path %}
      <div class="slide-image-wrap">
        <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
        <div class="slide-image-overlay" aria-hidden="true"></div>
      </div>
      {% endif %}
      <div class="slide-bleed-foreground">
        {{ slide_inner(slide, slides) }}
      </div>

      {% elif vt == 'top_band' %}
      {% if slide.image_path %}
      <div class="slide-top-band">
        <div class="slide-media-frame">
          <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
        </div>
      </div>
      {% endif %}
      <div class="slide-stack-body">
        {{ slide_inner(slide, slides) }}
      </div>

      {% elif vt == 'split_right' %}
      <div class="slide-split slide-split-right{% if not slide.image_path %} slide-split-single{% endif %}">
        <div class="slide-text-col">
          {{ slide_inner(slide, slides) }}
        </div>
        {% if slide.image_path %}
        <div class="slide-media-col">
          <div class="slide-media-frame">
            <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
          </div>
        </div>
        {% endif %}
      </div>

      {% elif vt == 'split_left' %}
      <div class="slide-split slide-split-left{% if not slide.image_path %} slide-split-single{% endif %}">
        {% if slide.image_path %}
        <div class="slide-media-col">
          <div class="slide-media-frame">
            <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
          </div>
        </div>
        {% endif %}
        <div class="slide-text-col">
          {{ slide_inner(slide, slides) }}
        </div>
      </div>

      {% elif vt == 'inset_card' %}
      <div class="slide-inset-shell{% if not slide.image_path %} slide-inset-single{% endif %}">
        <div class="slide-inset-main">
          {{ slide_inner(slide, slides) }}
        </div>
        {% if slide.image_path %}
        <aside class="slide-inset-aside" aria-hidden="true">
          <div class="slide-media-frame">
            <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
          </div>
        </aside>
        {% endif %}
      </div>

      {% elif vt == 'none' %}
      <div class="slide-visual-none-inner">
        {{ slide_inner(slide, slides) }}
      </div>

      {% else %}
      {% if slide.image_path %}
      <div class="slide-image-wrap">
        <img class="slide-image" src="{{ slide.image_path }}" alt="" draggable="false" />
        <div class="slide-image-overlay" aria-hidden="true"></div>
      </div>
      {% endif %}
      <div class="slide-bleed-foreground">
        {{ slide_inner(slide, slides) }}
      </div>
      {% endif %}

      <div class="slide-index">Sudar</div>
    </section>
    {% endfor %}
  </div>
      </div>
    </div>
  </div>

  {% if include_tts %}
  <audio id="SudarVidVoiceover" src="audio/voiceover.mp3" preload="auto"></audio>
  {% endif %}

  <div id="sudarvid-chrome">
  <div id="sudarvid-caption-wrap">
    <p id="sudarvid-caption" class="sudarvid-caption" aria-live="polite"></p>
  </div>
  <div id="sudarvid-player-ui" role="group" aria-label="Presentation playback">
    <button type="button" id="sudarvid-btn-prev" aria-label="Previous slide">Prev</button>
    <button type="button" id="sudarvid-btn-play" aria-label="Play">Play</button>
    <button type="button" id="sudarvid-btn-next" aria-label="Next slide">Next</button>
    <div id="sudarvid-timeline" role="slider" aria-label="Deck timeline">
      <div id="sudarvid-timeline-fill" aria-hidden="true"></div>
    </div>
    <input type="range" id="sudarvid-scrub" min="0" max="1000" value="0" aria-label="Seek along deck" />
    <span id="sudarvid-time">0:00 / 0:00</span>
    <p id="sudarvid-hint">Space: play/pause · ← →: slides · Home/End: start/end</p>
  </div>
  </div>

  <script>
    window.SUDARVID_SLIDES = [
      {% for slide in slides %}
      {
        "index": {{ slide.index }},
        "duration": {{ slide.duration_seconds }},
        "visual_template": {{ slide.visual_template | default('full_bleed_bg') | tojson }},
        "narration": {{ (slide.narration or '') | tojson }},
        "caption_words": {{ (slide.caption_words or []) | tojson }},
        "caption_times_ms": {{ (slide.caption_times_ms or []) | tojson }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ];
    window.SUDARVID_ANIMATION_LEVEL = {{ animation_level | tojson }};
    window.IS_CAPTURE = false; // overridden by Playwright before load
  </script>
  <script>
    (function () {
      if (window.IS_CAPTURE) return;
      function fitDeck() {
        var stage = document.getElementById("sudarvid-deck-stage");
        var vp = document.getElementById("deck-viewport");
        var inner = document.getElementById("deck-scale-inner");
        var deck = document.getElementById("deck");
        var chrome = document.getElementById("sudarvid-chrome");
        if (!stage || !vp || !inner || !deck) return;
        var w = deck.offsetWidth;
        var h = deck.offsetHeight;
        var chromeH = chrome ? chrome.offsetHeight : 0;
        var pad = 12;
        var availW = window.innerWidth - pad;
        var availH = window.innerHeight - chromeH - pad;
        if (availW <= 0 || availH <= 0) return;
        var mode = window.SUDARVID_FIT || "cover";
        var sx = availW / w;
        var sy = availH / h;
        var s = mode === "contain" ? Math.min(sx, sy) : Math.max(sx, sy);
        inner.style.width = w + "px";
        inner.style.height = h + "px";
        inner.style.transform =
          "translate(" + ((availW - w * s) / 2) + "px," + ((availH - h * s) / 2) + "px) scale(" + s + ")";
        vp.style.width = availW + "px";
        vp.style.height = availH + "px";
      }
      window.addEventListener("resize", fitDeck);
      var chrome = document.getElementById("sudarvid-chrome");
      if (chrome && typeof ResizeObserver !== "undefined") {
        var ro = new ResizeObserver(function () {
          fitDeck();
        });
        ro.observe(chrome);
      }
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fitDeck);
      } else {
        fitDeck();
      }
      requestAnimationFrame(fitDeck);
    })();
  </script>
  <script src="static/js/sudarvid.js"></script>
</body>
</html>

