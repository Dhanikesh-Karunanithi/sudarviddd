# SudarVid environment variables
#
# 1. Copy this file to .env in the project root (same folder as requirements.txt):
#    cp .env.example .env   (Linux/Mac)
#    copy .env.example .env (Windows)
#
# 2. Edit .env and replace the placeholder with your real API key.
# 3. Do not commit .env — it is in .gitignore.
#
# The app loads .env automatically when you run the CLI or the FastAPI server.

# Together AI API key (required for content planning and image generation)
# Get one at https://api.together.xyz/
TOGETHER_API_KEY=your_together_api_key_here

# Text model for slide planning (Together chat completions).
# Default in code is openai/gpt-oss-20b (reliable JSON). Override only if you accept risk:
# TOGETHER_TEXT_MODEL=ServiceNow-AI/Apriel-1.6-15b-Thinker
#
# Optional: ask the API for JSON object mode (works on many Together chat models):
# TOGETHER_JSON_RESPONSE=1

# Image model (optional; see sudarvid/image_gen.py for default)
# TOGETHER_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Optional: override default paths or behaviour
# OUTPUT_DIR=output
# CUSTOM_MUSIC_PATH=
